# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Build / dist ─────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Packaging ────────────────────────────────────────────────
pip-wheel-metadata/
pip-log.txt

# ── Test / coverage ──────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Type checking ────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Ruff / linting cache ─────────────────────────────────────
.ruff_cache/

# ── Environment & secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Alembic ──────────────────────────────────────────────────
# Keep versions/ directory but ignore compiled migrations
alembic/versions/*.pyc

# ── Local storage (uploaded files) ───────────────────────────
local_storage/
uploads/

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
